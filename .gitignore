# Dependencies
frontend/node_modules/

# Build output (rebuilt on deploy)
frontend/build/

# Duplicated source in public (if any)
frontend/public/src/

# Python
backend/__pycache__/
*.pyc
*.pyo

# Data files
# Keep parquet files tracked (needed for deploy/runtime data on Render)
backend/data/*.xlsx
backend/*.xlsx

# Beta data: ignore bulky CSV outputs when parquet equivalents exist.
# Keep a small set of CSVs that are still required by current beta endpoints.
backend/data_beta/*.csv
backend/data_beta/process_risk_outputs/*.csv
backend/data_beta/standalone_outputs/*.csv
!backend/data_beta/dynamic_catalog.csv
!backend/data_beta/dynamic_weights.csv
!backend/data_beta/initial_sensor_validation_report.csv
!backend/data_beta/sensor_config.csv
!backend/data_beta/subsystem_summary.csv
!backend/data_beta/system_summary.csv

# Generated pipeline output folders
backend/pipeline_outputs_*/
backend/NEW/
backend/data_beta_deployed/

# Pipeline artifacts
backend/pipeline.log
backend/pipeline.done

# Video assets
*.mp4

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Environment
.env
.env.*
